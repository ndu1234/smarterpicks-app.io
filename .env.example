# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# ── Whop ───────────────────────────────────────────────────────────────────────
WHOP_API_KEY=apik_xxxxxxxxxx
WHOP_CLIENT_ID=your_whop_oauth_client_id
WHOP_CLIENT_SECRET=your_whop_oauth_client_secret
WHOP_REDIRECT_URI=smarterpicks://oauth

# ── The Odds API ───────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key

# ── Vercel Postgres (auto-populated by Vercel when you add the integration) ────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Security ───────────────────────────────────────────────────────────────────
# Random secret to protect cron endpoints — generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── Expo (public — safe to expose to client) ───────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-project.vercel.app
EXPO_PUBLIC_WHOP_CLIENT_ID=your_whop_oauth_client_id
